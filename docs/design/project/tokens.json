{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$meta": {
    "name": "homefit.studio",
    "version": "1.0.0",
    "mode": "dark-first (light mirror defined)",
    "updated": "2026-04-18",
    "source-of-truth": true,
    "targets": ["app/lib/theme.dart", "web-player/styles.css", "web-portal/tailwind.config.ts"]
  },

  "color": {
    "brand": {
      "default":  { "$value": "#FF6B35", "$description": "Coral. Single accent. Never paired with a second brand colour." },
      "dark":     { "$value": "#E85A24", "$description": "Pressed / hover-dark state for primary." },
      "light":    { "$value": "#FF8F5E", "$description": "Hover-lift state for primary. Also used for brand text on dark." },
      "surface":  { "$value": "#FFF3ED", "$description": "Coral-tinted light surface. Used in light mode only." },
      "tint-bg":      { "$value": "rgba(255,107,53,0.12)", "$description": "Coral @ 12% \u2014 subtle fill behind brand text / chips." },
      "tint-border":  { "$value": "rgba(255,107,53,0.30)", "$description": "Coral @ 30% \u2014 border on tinted chips / focus rings." }
    },

    "surface": {
      "dark": {
        "bg":      { "$value": "#0F1117", "$description": "App root background. Deepest surface." },
        "base":    { "$value": "#1A1D27", "$description": "Card / sheet default. Elevation 1." },
        "raised":  { "$value": "#242733", "$description": "Popover, modal, hovered card. Elevation 2." },
        "border":  { "$value": "#2E3140", "$description": "1px hairline. Replaces shadow for separation." }
      },
      "light": {
        "bg":      { "$value": "#FAFAF7", "$description": "Mirror of dark.bg. Off-white with warm tone." },
        "base":    { "$value": "#FFFFFF", "$description": "Mirror of dark.base." },
        "raised":  { "$value": "#F5F5F0", "$description": "Mirror of dark.raised." },
        "border":  { "$value": "#E5E7EB", "$description": "Mirror of dark.border." }
      }
    },

    "ink": {
      "dark": {
        "primary":    { "$value": "#F0F0F5", "$description": "Primary text on dark surfaces." },
        "secondary":  { "$value": "#9CA3AF", "$description": "Secondary text \u2014 labels, meta, timestamps. Resolves drift: was #6B7280 on web player." },
        "muted":      { "$value": "#6B7280", "$description": "Tertiary text \u2014 placeholders, helper text, disabled labels." },
        "disabled":   { "$value": "#4B5563", "$description": "Disabled text on dark." }
      },
      "light": {
        "primary":    { "$value": "#0F1117", "$description": "Primary text on light surfaces." },
        "secondary":  { "$value": "#4B5563" },
        "muted":      { "$value": "#6B7280" },
        "disabled":   { "$value": "#9CA3AF" }
      },
      "on-brand":     { "$value": "#FFFFFF", "$description": "Text / icons sitting on coral fill." }
    },

    "semantic": {
      "success":  { "$value": "#22C55E", "$description": "Completion, published, credits added." },
      "warning":  { "$value": "#F59E0B", "$description": "Low credits, about to expire, POPIA cautions." },
      "error":    { "$value": "#EF4444", "$description": "Validation, auth fail, network down." },
      "rest":     { "$value": "#64748B", "$description": "Blue-grey. Distinct category \u2014 rest periods, not an accent." }
    }
  },

  "typography": {
    "family": {
      "display":  { "$value": "Montserrat", "$description": "Headlines, titles, display. 400/600/700/800." },
      "body":     { "$value": "Inter",      "$description": "Body, labels, UI. 400/500/600/700." },
      "mono":     { "$value": "JetBrains Mono", "$description": "Code, IDs, credits balance numerals." }
    },
    "scale": {
      "display.lg":   { "family": "display", "size": 57, "weight": 800, "letter-spacing": -1.5, "line-height": 1.05 },
      "display.md":   { "family": "display", "size": 45, "weight": 700, "letter-spacing": -0.5, "line-height": 1.1 },
      "display.sm":   { "family": "display", "size": 36, "weight": 700, "letter-spacing": -0.3, "line-height": 1.15 },
      "headline.lg":  { "family": "display", "size": 32, "weight": 700, "letter-spacing": -0.5, "line-height": 1.2 },
      "headline.md":  { "family": "display", "size": 28, "weight": 700, "letter-spacing": -0.3, "line-height": 1.25 },
      "headline.sm":  { "family": "display", "size": 24, "weight": 600, "letter-spacing": -0.2, "line-height": 1.3 },
      "title.lg":     { "family": "display", "size": 20, "weight": 700, "letter-spacing": -0.3, "line-height": 1.35 },
      "title.md":     { "family": "body",    "size": 16, "weight": 600, "letter-spacing": 0,    "line-height": 1.4 },
      "title.sm":     { "family": "body",    "size": 14, "weight": 600, "letter-spacing": 0,    "line-height": 1.4 },
      "body.lg":      { "family": "body",    "size": 16, "weight": 400, "letter-spacing": 0,    "line-height": 1.5 },
      "body.md":      { "family": "body",    "size": 14, "weight": 400, "letter-spacing": 0,    "line-height": 1.5 },
      "body.sm":      { "family": "body",    "size": 12, "weight": 400, "letter-spacing": 0,    "line-height": 1.5 },
      "label.lg":     { "family": "body",    "size": 14, "weight": 600, "letter-spacing": 0.1,  "line-height": 1.4 },
      "label.md":     { "family": "body",    "size": 12, "weight": 600, "letter-spacing": 0.5,  "line-height": 1.4 },
      "label.sm":     { "family": "body",    "size": 11, "weight": 600, "letter-spacing": 0.5,  "line-height": 1.4 }
    }
  },

  "spacing": {
    "0":  { "$value": 0 },
    "1":  { "$value": 4 },
    "2":  { "$value": 8 },
    "3":  { "$value": 12 },
    "4":  { "$value": 16 },
    "5":  { "$value": 20 },
    "6":  { "$value": 24 },
    "8":  { "$value": 32 },
    "10": { "$value": 40 },
    "12": { "$value": 48 },
    "16": { "$value": 64 },
    "$description": "4/8/12/16/20/24/32/40/48/64 \u2014 matches de-facto Flutter usage. Missing 28/36/56 intentionally \u2014 pick the nearest."
  },

  "radius": {
    "sm":   { "$value": 8 },
    "md":   { "$value": 12 },
    "lg":   { "$value": 16 },
    "xl":   { "$value": 20 },
    "full": { "$value": 9999, "$description": "Pills, avatars, timer chip." }
  },

  "shadow": {
    "$description": "Flat posture \u2014 shadows killed on all three surfaces. Use surface.border (1px) for separation. Brand-glow reserved for focus ring only.",
    "none":         { "$value": "none" },
    "focus-ring":   { "$value": "0 0 0 3px rgba(255,107,53,0.30)", "$description": "Only shadow-ish token. Keyboard focus on interactive elements." }
  },

  "motion": {
    "duration": {
      "fast":    { "$value": "150ms" },
      "normal":  { "$value": "250ms" },
      "slow":    { "$value": "400ms" }
    },
    "easing": {
      "standard":  { "$value": "cubic-bezier(0.2, 0, 0, 1)",  "$description": "Default. Material-ish ease-out." },
      "emphasized":{ "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$description": "Entrances, modals, primary feedback." },
      "linear":    { "$value": "linear", "$description": "Progress bars, timer fills." }
    },
    "pulse": {
      "$value": "1.4s cubic-bezier(0.4, 0, 0.6, 1) infinite",
      "$description": "Pulse Mark heartbeat rhythm. 1.4s = 43bpm resting \u2014 slow, calm."
    }
  },

  "z-index": {
    "base":      { "$value": 0 },
    "raised":    { "$value": 10 },
    "sticky":    { "$value": 100 },
    "overlay":   { "$value": 500 },
    "modal":     { "$value": 1000 },
    "toast":     { "$value": 2000 }
  },

  "breakpoints": {
    "$description": "Web portal + web player. Flutter uses MediaQuery, not these.",
    "sm": { "$value": 640 },
    "md": { "$value": 768 },
    "lg": { "$value": 1024 },
    "xl": { "$value": 1280 }
  }
}
