# Motion Service Selection
MOTION_SERVICE=hy_motion  # or "saymotion" as fallback

# HY-Motion Configuration (Tencent, open-source, free)
HY_MOTION_MODE=runpod     # or "local" if you have a local GPU
HY_MOTION_RUNPOD_SSH=ssh root@xyz.runpod.io -i ~/.ssh/runpod_key
# Get your actual SSH string from RunPod console after launching a pod

# SayMotion Configuration (DeepMotion API) - FALLBACK ONLY
SAYMOTION_CLIENT_ID=your_client_id_here
SAYMOTION_CLIENT_SECRET=your_client_secret_here

# Replicate API (for ControlNet rendering)
REPLICATE_API_TOKEN=your_replicate_token_here

# Logging
LOG_LEVEL=INFO
