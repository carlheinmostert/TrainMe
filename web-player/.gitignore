# Generated by build.sh from Vercel-injected env vars at deploy time.
# Source-of-truth lives in NEXT_PUBLIC_SUPABASE_URL +
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY on the Vercel project.
# build.sh enforces strict-fail when those env vars are absent —
# generate locally via `vercel dev` or by exporting them manually
# before invoking build.sh.
config.js

# Vercel CLI link state — `vercel link --cwd web-player` writes here.
.vercel/
