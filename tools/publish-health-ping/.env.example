# Copy to .env and fill in the blanks before running ping.sh.

# Supabase project URL (no trailing slash).
SUPABASE_URL=https://yrwcofhovrcydootivjx.supabase.co

# Service role key — service_role has SELECT on every table including the
# new publish_health view (which is already RLS-scoped, but the service
# role bypasses RLS so we can aggregate across the whole fleet in one
# query). NEVER commit the real value — .env is in .gitignore above.
SUPABASE_SERVICE_KEY=

# CallMeBot WhatsApp target phone (full international form, leading +).
# Per the project guidelines the default recipient is Carl; that's the
# expectation unless someone hands you a different number.
CALLMEBOT_PHONE=

# CallMeBot API key. Obtain once per phone number by messaging CallMeBot
# on WhatsApp — see https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_APIKEY=
