# Supabase (shared with the Flutter app and web player).
# The anon key is a publishable key — safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://yrwcofhovrcydootivjx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_cwhfavfji552BN8X0uPIpA_pwWQ-gw3

# NEVER ship the service role key to the client. Only used server-side by
# the /credits/purchase route to insert a `pending_payments` intent row.
# Copy the service_role JWT from the Supabase dashboard → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# Public URL the portal is served from. Used to build PayFast return_url
# and cancel_url. Must be reachable by the buyer's browser — PayFast
# bounces them back here after checkout. Defaults to localhost for dev.
APP_URL=http://localhost:3000

# Same portal URL but visible to client bundles — required for
# referral-share URLs (which render in client components). Set to the
# same host as APP_URL above. A9 (HARDCODED-AUDIT-2026-05-12) — the
# previous silent fallback to https://manage.homefit.studio is gone;
# requireEnv() throws at runtime if this is missing.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public URL of the client-facing web player. Used by SessionsList (the
# "open in player" link on session cards) and the audit-row "Player"
# link. A7/A8 (HARDCODED-AUDIT-2026-05-12) — env-aware: a staging
# portal deploy MUST set this to https://staging.session.homefit.studio.
NEXT_PUBLIC_WEB_PLAYER_BASE_URL=https://session.homefit.studio

# PayFast — sandbox credentials are public and safe to commit. Swap to
# your real merchant creds in production and flip PAYFAST_SANDBOX to false.
# Docs: https://developers.payfast.co.za/docs
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
# The shared sandbox account now requires PayFast's default sandbox passphrase.
# Sending empty produces: "Generated signature does not match submitted signature" (400).
# For production, swap to YOUR merchant passphrase (or empty if none is configured).
PAYFAST_PASSPHRASE=jt7NOE43FZPn
PAYFAST_SANDBOX=true
