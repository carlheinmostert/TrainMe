# Dependencies
node_modules/
venv/
.venv/
__pycache__/
*.pyc

# Environment
.env
.env.local
.env.*.local
# Agent QA credentials (staging-only test account; see docs/AGENT_QA_AUTH.md).
# Never commit — generated locally by the keep-auth setup. Covered by the
# upstream `.env.*.local` pattern too, but called out explicitly so the
# intent is obvious.
.env.test

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build
dist/
build/
*.egg-info/

# AI/ML
*.ckpt
*.safetensors
*.bin
/models/
/prototype/models/
checkpoints/
!app/lib/models/

# Prototype outputs
prototype/output/
prototype/frames/
*.mp4
*.avi

# Supabase CLI local state
**/supabase/.temp/
**/supabase/.branches/

# Flutter
app/.dart_tool/
app/.packages
app/build/
app/pubspec.lock
app/ios/Pods/
app/ios/.symlinks/
app/android/.gradle/
app/android/local.properties
*.iml

# install-device.sh dart-define fingerprint sentinel — used to auto-clean
# Flutter's kernel cache when GIT_SHA / ENV / SUPABASE_URL change between
# builds (see install-device.sh header).
app/.last_dart_define_fingerprint

# Test-script runtime output — tester's per-click pass/fail journal,
# written by docs/test-scripts/_server.py. Mid-QA state is not worth
# tracking; commit with `git add -f` only at wave close as an audit
# trail (see feedback_test_scripts_as_markdown.md for workflow).
docs/test-scripts/*.results.json

# Claude — ignore most of .claude (transient worktrees, launch.json,
# personal overrides in settings.local.json) but share the project-level
# settings.json + hooks/ dir so teammates inherit the repo-wide rules.
# Note: `.claude/*` (not `.claude/`) so git still recurses into the dir
# — ignoring the directory itself would block negation patterns below.
.claude/*
!.claude/settings.json
!.claude/hooks
!.claude/hooks/**
# Per-developer hook state (orphan-agent registry + brief sidecars
# written by record-agent-dispatch.py). Already covered by `.claude/*`
# above, but called out explicitly so the intent is obvious.
.claude/state/
